# --- Server runtime ---
NODE_ENV=development
PORT=5000

# --- Database ---
MONGO_URI=mongodb://127.0.0.1:27017/codenest

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# --- CORS / Client origin ---
CORS_ORIGIN=http://localhost:5173

# --- Piston (code execution proxy) ---
PISTON_BASE_URL=https://emkc.org/api/v2/piston

# --- Cloudinary (avatar uploads, optional) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Initial admin (used by `npm run seed`) ---
ADMIN_EMAIL=admin@codenest.local
ADMIN_PASSWORD=ChangeMe!2026

# --- Code execution payload ---
MAX_CODE_PAYLOAD_KB=64
